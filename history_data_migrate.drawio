        <mxCell id="6" value="meta-governance 控制面" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;overflow=visible;rounded=0;fontSize=19;fontStyle=1;fontColor=#172033;fontFamily=PingFang SC,Microsoft YaHei,Arial;" vertex="1" parent="1">
          <mxGeometry x="963.84" y="512.95" width="272.33" height="27.75" as="geometry" />
        </mxCell>
        <mxCell id="7" value="固定 worker pool + 同表运行保护" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;overflow=visible;rounded=0;fontSize=15;fontStyle=1;fontColor=#475569;fontFamily=PingFang SC,Microsoft YaHei,Arial;" vertex="1" parent="1">
          <mxGeometry x="955.25" y="542.75" width="289.5" height="23" as="geometry" />
