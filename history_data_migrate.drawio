        <mxCell id="12" value="只读路由、聚合、分页物化" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;overflow=visible;rounded=0;fontSize=15;fontStyle=1;fontColor=#475569;fontFamily=PingFang SC,Microsoft YaHei,Arial;" vertex="1" parent="1">
