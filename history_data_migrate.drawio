        <mxCell id="8" value="阶段状态持久化；失败停在边界" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;overflow=visible;rounded=0;fontSize=15;fontStyle=1;fontColor=#475569;fontFamily=PingFang SC,Microsoft YaHei,Arial;" vertex="1" parent="1">
          <mxGeometry x="977.75" y="562.75" width="244.5" height="23" as="geometry" />
