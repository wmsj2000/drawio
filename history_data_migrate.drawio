        <mxCell id="21" value="HiveServer2" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;overflow=visible;rounded=0;fontSize=19;fontStyle=1;fontColor=#172033;fontFamily=PingFang SC,Microsoft YaHei,Arial;" vertex="1" parent="1">
          <mxGeometry x="253.21" y="786.95" width="153.58" height="27.75" as="geometry" />
